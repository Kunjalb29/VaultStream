{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=VaultStreamDb;Username=postgres;Password=postgres"
  },
  "JwtSettings": {
    "Secret": "SuperSecretKeyForVaultStreamDevelopmentEnvironmentOnly",
    "Issuer": "VaultStreamApi",
    "Audience": "VaultStreamClients",
    "ExpirationInMinutes": 60
  },
  "AzureBlobStorage": {
    "ConnectionString": "UseDevelopmentStorage=true;",
    "ContainerName": "software-packages",
    "CdnEndpoint": "https://vaultstream.azureedge.net/"
  }
}
